local lib = require("prototypes.lib")

local use_leading = lib.setting("br-turret-leading")
local ammo_buffer = lib.setting("br-turret-ammo-buffer") or 3

local explicit_lead_speeds = {
  ["gun-turret"] = 1.05,
  ["rifle-ammo-turret-rampant-arsenal"] = 1.05,
  ["gun-ammo-turret-rampant-arsenal"] = 1.05,
  ["shotgun-ammo-turret-rampant-arsenal"] = 1.05,
  ["rocket-ammo-turret-rampant-arsenal"] = 0.55,
  ["rapid-rocket-ammo-turret-rampant-arsenal"] = 0.55,
  ["cannon-ammo-turret-rampant-arsenal"] = 0.80,
  ["rapid-cannon-ammo-turret-rampant-arsenal"] = 0.80
}

local category_lead_speeds = {
  bullet = 1.05,
  ["shotgun-shell"] = 1.05,
  rocket = 0.55,
  ["cannon-shell"] = 0.80
}

local function lead_speed_for(turret)
  if explicit_lead_speeds[turret.name] then return explicit_lead_speeds[turret.name] end
  local attack = turret.attack_parameters
  if not attack then return nil end
  if attack.ammo_category and category_lead_speeds[attack.ammo_category] then
    return category_lead_speeds[attack.ammo_category]
  end
  return nil
end

local function is_supported_ammo_turret(turret)
  local attack = turret and turret.attack_parameters
  if not attack then return false end
  if attack.ammo_category and category_lead_speeds[attack.ammo_category] then return true end
  if explicit_lead_speeds[turret.name] then return true end
  return false
end

for _, turret in pairs(data.raw["ammo-turret"] or {}) do
  if is_supported_ammo_turret(turret) then
    if ammo_buffer and ammo_buffer > 1 then
      turret.inventory_size = math.max(turret.inventory_size or 1, ammo_buffer)
    end

    if use_leading and turret.attack_parameters then
      local speed = lead_speed_for(turret)
      if speed then
        turret.attack_parameters.lead_target_for_projectile_speed = speed
      end
    end
  end
end
